{
  "name": "os8",
  "version": "0.2.6",
  "description": "OS8 - Desktop workspace for AI-assisted development",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "pretest": "npm rebuild better-sqlite3 --loglevel=error",
    "test": "vitest run",
    "test:watch": "npm rebuild better-sqlite3 --loglevel=error && vitest",
    "posttest": "npx @electron/rebuild -m . -o better-sqlite3 -s --loglevel=error",
    "postinstall": "npx @electron/rebuild -m . -o better-sqlite3",
    "verify:package-assets": "node tools/verify-package-assets.js",
    "verify:package-dist": "node tools/verify-package-assets.js --dist",
    "build": "npm run verify:package-assets && electron-builder --mac && npm run verify:package-dist",
    "build:dir": "npm run verify:package-assets && electron-builder --mac --dir && npm run verify:package-dist"
  },
  "keywords": [
    "electron",
    "ai",
    "cli",
    "workspace"
  ],
  "author": "Leo <leo@os8.ai>",
  "homepage": "https://os8.ai",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@electron/rebuild": "^4.0.3",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electron-reloader": "^1.2.3",
    "rollup": "^4.60.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^7.0.1",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^3.6.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "lru-cache": "^10.4.3",
    "multer": "^2.0.2",
    "node-pty": "^1.1.0",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.os8.app",
    "productName": "OS8",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "deb": {
      "depends": [
        "nodejs",
        "npm"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "styles/**/*",
      "src/**/*",
      "backgrounds/**/*",
      "build/**/*",
      "skills/**/*",
      "vendor/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
